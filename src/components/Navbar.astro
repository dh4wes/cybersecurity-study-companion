---
import { withBase } from '../lib/site-data.js';

const { currentPath = '/' } = Astro.props;
const links = [
  { path: '/', label: 'Dashboard' },
  { path: '/roadmap/', label: 'Roadmap' },
  { path: '/weeks/', label: 'Weeks' },
  { path: '/resources/', label: 'Resources' },
  { path: '/security-journal/', label: 'Journal' },
  { path: '/progress/', label: 'Progress' },
  { path: '/about/', label: 'About' }
];

const normalize = (value) => String(value || '/').replace(/\/?$/, '/');
const normalizedPath = normalize(currentPath);

const isActive = (path) => {
  const href = normalize(withBase(path));
  if (path === '/') return normalizedPath === href;
  return normalizedPath === href || normalizedPath.startsWith(href);
};
---

<header class="site-header">
  <div class="masthead">
    <div>
      <p class="eyebrow">Study Companion v1.0</p>
      <a class="brand" href={withBase('/')}>Cyber Security</a>
    </div>
    <p class="context">32-Week Cybersecurity Roadmap and Proof-of-Work Portfolio</p>
  </div>

  <nav aria-label="Primary" class="site-nav">
    <ul>
      {links.map((link) => (
        <li>
          <a class={isActive(link.path) ? 'active' : ''} href={withBase(link.path)}>{link.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--bg) 93%, #ffffff 7%);
    border-bottom: 1px solid var(--border);
  }

  .masthead {
    width: min(1160px, 95vw);
    margin: 0 auto;
    padding: 0.85rem 0;
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
  }

  .eyebrow {
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 0.3rem;
    font-weight: 600;
  }

  .brand {
    font-family: 'Cinzel', serif;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1;
    font-size: 1.85rem;
    color: var(--ink);
  }

  .brand:hover,
  .brand:focus-visible {
    text-decoration: none;
    color: var(--accent-dark);
  }

  .context {
    margin: 0;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-soft);
    text-align: right;
    max-width: 360px;
    font-weight: 600;
  }

  .site-nav {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .site-nav ul {
    width: min(1160px, 95vw);
    margin: 0 auto;
    padding: 0;
    list-style: none;
    display: flex;
    align-items: center;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .site-nav ul::-webkit-scrollbar {
    display: none;
  }

  .site-nav li {
    border-right: 1px solid var(--border);
  }

  .site-nav li:first-child {
    border-left: 1px solid var(--border);
  }

  .site-nav a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.8rem 1rem;
    min-height: 46px;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink);
    white-space: nowrap;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .site-nav a:hover,
  .site-nav a:focus-visible {
    background: var(--surface-soft);
    text-decoration: none;
  }

  .site-nav a.active {
    background: var(--accent);
    color: #fff;
  }

  @media (max-width: 900px) {
    .masthead {
      align-items: flex-start;
      flex-direction: column;
      padding: 0.72rem 0;
    }

    .brand {
      font-size: 1.45rem;
    }

    .context {
      text-align: left;
      max-width: none;
    }

    .site-nav a {
      padding: 0.72rem 0.9rem;
    }
  }
</style>
