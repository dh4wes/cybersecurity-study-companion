---
import { withBase } from '../lib/site-data.js';

const { currentPath = '/' } = Astro.props;
const links = [
  { path: '/', label: 'Home' },
  { path: '/roadmap/', label: 'Roadmap' },
  { path: '/weeks/', label: 'Weeks' },
  { path: '/resources/', label: 'Resources' },
  { path: '/glossary/', label: 'Glossary' },
  { path: '/flashcards/', label: 'Flashcards' },
  { path: '/security-journal/', label: 'Journal' },
  { path: '/progress/', label: 'Progress' },
  { path: '/notes/', label: 'Notes' },
  { path: '/about/', label: 'About' }
];

const normalize = (value) => String(value || '/').replace(/\/?$/, '/');
const normalizedPath = normalize(currentPath);

const isActive = (path) => {
  const href = normalize(withBase(path));
  if (path === '/') return normalizedPath === href;
  return normalizedPath === href || normalizedPath.startsWith(href);
};
---

<header class="site-header">
  <div class="masthead">
    <div>
      <p class="eyebrow">Study Companion v2</p>
      <a class="brand" href={withBase('/')}>Cybersecurity Study Companion</a>
    </div>
    <div class="context-wrap">
      <p class="context">32-week roadmap, static portfolio, and private local notes tool</p>
      <label class="font-switcher">
        <span>Font Theme</span>
        <select class="js-font-theme" aria-label="Select font theme">
          <option value="default">Default</option>
          <option value="pinkend">Pinkend</option>
        </select>
      </label>
    </div>
  </div>

  <nav aria-label="Primary" class="site-nav">
    <ul>
      {links.map((link) => (
        <li>
          <a class={isActive(link.path) ? 'active' : ''} href={withBase(link.path)}>{link.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  import '../scripts/font-theme.js';
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    backdrop-filter: blur(8px);
    background: rgba(244, 248, 255, 0.94);
    border-bottom: 1px solid var(--border);
  }

  .masthead {
    width: min(1160px, 95vw);
    margin: 0 auto;
    padding: 0.85rem 0;
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
  }

  .eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-dark);
    margin-bottom: 0.32rem;
    font-weight: 700;
  }

  .brand {
    font-family: var(--font-display);
    letter-spacing: 0.01em;
    line-height: 1;
    font-size: 1.44rem;
    color: var(--ink);
    border-bottom-color: transparent;
  }

  .brand:hover,
  .brand:focus-visible {
    color: var(--accent-dark);
    border-bottom-color: transparent;
  }

  .context {
    margin: 0;
    font-size: 0.72rem;
    color: var(--ink-light);
    text-align: right;
    max-width: 380px;
    font-weight: 600;
  }

  .context-wrap {
    display: grid;
    gap: 0.45rem;
    justify-items: end;
  }

  .font-switcher {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.68rem;
    color: var(--ink-light);
    font-weight: 700;
  }

  .font-switcher select {
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--ink);
    padding: 0.25rem 0.42rem;
    border-radius: 8px;
    font-size: 0.68rem;
    min-width: 120px;
  }

  .site-nav {
    border-top: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.85);
  }

  .site-nav ul {
    width: min(1160px, 95vw);
    margin: 0 auto;
    padding: 0.2rem 0;
    list-style: none;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .site-nav a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.45rem 0.62rem;
    min-height: 36px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: var(--ink-soft);
    white-space: nowrap;
    border: 1px solid transparent;
    border-radius: 999px;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .site-nav a:hover,
  .site-nav a:focus-visible {
    background: var(--accent-soft);
    color: var(--accent-dark);
    border-color: #b6cae8;
    text-decoration: none;
  }

  .site-nav a.active {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  @media (max-width: 900px) {
    .masthead {
      align-items: flex-start;
      flex-direction: column;
      padding: 0.72rem 0;
    }

    .brand {
      font-size: 1.2rem;
    }

    .context {
      text-align: left;
      max-width: none;
    }

    .context-wrap {
      justify-items: start;
    }

    .site-nav ul {
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: 0.36rem;
      scrollbar-width: thin;
    }
  }
</style>
