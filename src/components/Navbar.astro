---
import { withBase } from '../lib/site-data.js';

const { currentPath = '/' } = Astro.props;
const links = [
  { path: '/', label: 'Home' },
  { path: '/roadmap/', label: 'Roadmap' },
  { path: '/weeks/', label: 'Weeks' },
  { path: '/resources/', label: 'Resources' },
  { path: '/glossary/', label: 'Glossary' },
  { path: '/flashcards/', label: 'Flashcards' },
  { path: '/security-journal/', label: 'Journal' },
  { path: '/progress/', label: 'Progress' },
  { path: '/notes/', label: 'Notes' },
  { path: '/about/', label: 'About' }
];
const mobileLinks = links.filter((link) =>
  ['/', '/weeks/', '/flashcards/', '/progress/', '/notes/'].includes(link.path)
);

const normalize = (value) => String(value || '/').replace(/\/?$/, '/');
const normalizedPath = normalize(currentPath);

const isActive = (path) => {
  const href = normalize(withBase(path));
  if (path === '/') return normalizedPath === href;
  return normalizedPath === href || normalizedPath.startsWith(href);
};
---

<header class="site-header">
  <div class="masthead">
    <div>
      <p class="eyebrow">Study Companion v2</p>
      <a class="brand" href={withBase('/')}>Cybersecurity Study Companion</a>
    </div>
    <div class="context-wrap">
      <p class="context">32-week roadmap, static portfolio, and private local notes tool</p>
      <div class="theme-controls">
        <label class="theme-switcher">
          <span>Type</span>
          <select class="js-font-theme" aria-label="Select typography theme">
            <option value="default">Default</option>
            <option value="ops-console">Ops Console</option>
            <option value="editor-clean">Editor Clean</option>
            <option value="mono-range">Mono Range</option>
          </select>
        </label>
        <label class="theme-switcher">
          <span>Color</span>
          <select class="js-color-theme" aria-label="Select color theme">
            <option value="default">Current</option>
            <option value="inked">Inked</option>
            <option value="amethyst-mint-harmony">Amethyst Mint</option>
            <option value="woodland">Woodland</option>
            <option value="jade-pebble-morning">Jade Pebble</option>
            <option value="cocoa-topaz-noonday">Cocoa Topaz</option>
            <option value="sorbet">Sorbet</option>
            <option value="pearl">Pearl</option>
            <option value="driftwood-pearl-morning">Driftwood Pearl</option>
            <option value="graphite">Graphite</option>
          </select>
        </label>
      </div>
    </div>
  </div>

  <nav aria-label="Primary" class="site-nav">
    <ul>
      {links.map((link) => (
        <li>
          <a class={isActive(link.path) ? 'active' : ''} href={withBase(link.path)}>{link.label}</a>
        </li>
      ))}
    </ul>
  </nav>

  <nav aria-label="Mobile" class="mobile-nav">
    <ul>
      {mobileLinks.map((link) => (
        <li>
          <a class={isActive(link.path) ? 'active' : ''} href={withBase(link.path)}>{link.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  import '../scripts/color-theme.js';
  import '../scripts/font-theme.js';
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: var(--header-bg);
    border-bottom: 1px solid var(--border);
  }

  .site-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: repeating-linear-gradient(
      90deg,
      var(--accent) 0,
      var(--accent) 6px,
      transparent 6px,
      transparent 12px
    );
    pointer-events: none;
  }

  .masthead {
    width: min(1160px, 95vw);
    margin: 0 auto;
    padding: 0.9rem 0 0.8rem;
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
  }

  .eyebrow {
    font-size: 0.62rem;
    letter-spacing: var(--type-kicker-tracking);
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.3rem;
    font-weight: 700;
  }

  .brand {
    font-family: var(--type-heading-font);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1;
    font-size: 1.85rem;
    color: var(--accent);
    text-shadow: 0 0 10px var(--accent-shadow);
  }

  .brand:hover,
  .brand:focus-visible {
    text-decoration: none;
    color: var(--c-white);
    border-bottom-color: transparent;
  }

  .context {
    margin: 0;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: calc(var(--type-kicker-tracking) * 0.75);
    color: var(--ink-soft);
    text-align: right;
    max-width: 360px;
    font-weight: 600;
  }

  .context-wrap {
    display: grid;
    gap: 0.45rem;
    justify-items: end;
  }

  .theme-controls {
    display: flex;
    flex-wrap: wrap;
    justify-content: end;
    gap: 0.45rem;
  }

  .theme-switcher {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: calc(var(--type-kicker-tracking) * 0.75);
    color: var(--ink-soft);
    font-weight: 700;
  }

  .theme-switcher span {
    white-space: nowrap;
  }

  .theme-switcher select {
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--accent);
    padding: 0.22rem 0.38rem;
    border-radius: 0;
    font-size: 0.62rem;
    letter-spacing: calc(var(--type-kicker-tracking) * 0.4);
    text-transform: uppercase;
    min-width: 138px;
  }

  .site-nav {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--nav-bg);
  }

  .site-nav ul {
    width: min(1160px, 95vw);
    margin: 0 auto;
    padding: 0;
    list-style: none;
    display: flex;
    align-items: center;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .site-nav ul::-webkit-scrollbar {
    display: none;
  }

  .site-nav li {
    border-right: 1px solid var(--border);
  }

  .site-nav li:first-child {
    border-left: 1px solid var(--border);
  }

  .site-nav a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.8rem 1rem;
    min-height: 46px;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
    white-space: nowrap;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .site-nav a:hover,
  .site-nav a:focus-visible {
    background: var(--surface-hover-start);
    color: var(--accent);
    text-decoration: none;
  }

  .site-nav a.active {
    background: var(--accent);
    color: var(--accent-contrast);
  }

  .mobile-nav {
    display: none;
  }

  .mobile-nav ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }

  .mobile-nav a {
    min-height: 52px;
    display: grid;
    place-items: center;
    padding: 0.65rem 0.35rem calc(0.65rem + env(safe-area-inset-bottom));
    border-top: 1px solid var(--border);
    border-right: 1px solid var(--border);
    background: var(--mobile-nav-bg);
    color: var(--ink-soft);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: center;
  }

  .mobile-nav li:last-child a {
    border-right: none;
  }

  .mobile-nav a.active {
    background: var(--accent);
    color: var(--accent-contrast);
  }

  @media (max-width: 900px) {
    .masthead {
      align-items: flex-start;
      flex-direction: column;
      padding: 0.72rem 0;
    }

    .brand {
      font-size: 1.45rem;
    }

    .context {
      text-align: left;
      max-width: none;
    }

    .context-wrap {
      justify-items: start;
    }

    .theme-switcher select {
      min-width: 128px;
    }

    .site-nav {
      display: none;
    }

    .mobile-nav {
      display: block;
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 45;
      border-top: 1px solid var(--border);
      box-shadow: 0 -8px 24px rgba(0, 0, 0, 0.35);
    }
  }
</style>
