---
import { withBase } from '../lib/site-data.js';
import { colorThemeOptions, fontThemeOptions } from '../lib/theme-options.js';

const { currentPath = '/' } = Astro.props;
const links = [
  { path: '/', label: 'Home' },
  { path: '/roadmap/', label: 'Roadmap' },
  { path: '/resources/', label: 'Resources' },
  { path: '/glossary/', label: 'Glossary' },
  { path: '/flashcards/', label: 'Flashcards' },
  { path: '/security-journal/', label: 'Journal' },
  { path: '/progress/', label: 'Progress' },
  { path: '/notes/', label: 'Notes' },
  { path: '/about/', label: 'About' }
];
const mobileLinks = links.filter((link) =>
  ['/', '/roadmap/', '/flashcards/', '/progress/', '/notes/'].includes(link.path)
);

const normalize = (value) => String(value || '/').replace(/\/?$/, '/');
const normalizedPath = normalize(currentPath);

const isActive = (path) => {
  const href = normalize(withBase(path));
  if (path === '/') return normalizedPath === href;
  return normalizedPath === href || normalizedPath.startsWith(href);
};
---

<header class="site-header">
  <div class="desktop-header-row">
    <div class="desktop-header-shell">
      <div>
        <p class="eyebrow">Study Companion v2</p>
        <a class="brand" href={withBase('/')}>Cybersecurity Study Companion</a>
      </div>
      <div class="context-wrap">
        <div class="theme-controls">
          <label class="theme-switcher">
            <span>Type</span>
            <select class="js-font-theme" aria-label="Select typography theme">
              {fontThemeOptions.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </label>
          <label class="theme-switcher">
            <span>Color</span>
            <select class="js-color-theme" aria-label="Select color theme">
              {colorThemeOptions.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </label>
        </div>
      </div>
    </div>
  </div>

  <div class="banner-shell">
    <img
      class="banner-image banner-image-fill"
      src={withBase('/images/site-banner-optimized.jpg')}
      alt=""
      aria-hidden="true"
    />
    <img
      class="banner-image"
      src={withBase('/images/site-banner-optimized.jpg')}
      alt="Cybersecurity study guide banner art"
    />
    <div class="banner-overlay">
      <div class="masthead">
        <div>
          <p class="eyebrow">Study Companion v2</p>
          <a class="brand" href={withBase('/')}>Cybersecurity Study Companion</a>
        </div>
        <div class="context-wrap">
          <div class="theme-controls">
            <label class="theme-switcher">
              <span>Type</span>
              <select class="js-font-theme" aria-label="Select typography theme">
                {fontThemeOptions.map((option) => (
                  <option value={option.value}>{option.label}</option>
                ))}
              </select>
            </label>
            <label class="theme-switcher">
              <span>Color</span>
              <select class="js-color-theme" aria-label="Select color theme">
                {colorThemeOptions.map((option) => (
                  <option value={option.value}>{option.label}</option>
                ))}
              </select>
            </label>
          </div>
        </div>
      </div>
    </div>
  </div>

  <nav aria-label="Mobile" class="mobile-nav">
    <ul>
      {mobileLinks.map((link) => (
        <li>
          <a class={isActive(link.path) ? 'active' : ''} href={withBase(link.path)}>{link.label}</a>
        </li>
      ))}
    </ul>
  </nav>

  <nav aria-label="Primary" class="site-nav">
    <ul>
      {links.map((link) => (
        <li>
          <a class={isActive(link.path) ? 'active' : ''} href={withBase(link.path)}>{link.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  import '../scripts/color-theme.js';
  import '../scripts/font-theme.js';
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--header-bg) 88%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid color-mix(in srgb, var(--border) 75%, transparent);
  }

  .desktop-header-row {
    display: block;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
    background: color-mix(in srgb, var(--header-bg) 78%, transparent);
    backdrop-filter: blur(10px);
  }

  .desktop-header-shell {
    width: min(1160px, 95vw);
    margin: 0 auto;
    padding: 0.8rem 0;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .banner-shell {
    position: relative;
    height: clamp(240px, 34vw, 520px);
    overflow: hidden;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
    background: #8c7751;
  }

  .banner-shell::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: clamp(56px, 9vw, 88px);
    background: rgba(10, 11, 13, 0.42);
    z-index: 1;
    pointer-events: none;
  }

  .banner-shell::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(18, 15, 11, 0.1) 0%, rgba(18, 15, 11, 0) 22%, rgba(18, 15, 11, 0) 72%, rgba(8, 10, 12, 0.64) 100%);
    pointer-events: none;
  }

  .banner-image {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    object-position: center top;
  }

  .banner-image-fill {
    position: absolute;
    inset: -3%;
    z-index: 0;
    object-fit: cover;
    object-position: center 34%;
    filter: blur(26px) saturate(0.92);
    transform: scale(1.08);
    opacity: 0.9;
  }

  .masthead {
    width: min(1160px, 95vw);
    margin: 0 auto;
    padding: 0.9rem 0 0;
    display: flex;
    justify-content: space-between;
    align-items: start;
    gap: 1rem;
  }

  .banner-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .eyebrow {
    font-size: 0.62rem;
    letter-spacing: var(--type-kicker-tracking);
    text-transform: uppercase;
    color: #f4e9ce;
    margin-bottom: 0.3rem;
    font-weight: 700;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.55);
  }

  .brand {
    font-family: var(--type-heading-font);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1;
    font-size: clamp(1rem, 1.3vw, 1.2rem);
    color: #fff4dd;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.5);
    display: inline-block;
    padding: 0.35rem 0.55rem;
    background: rgba(15, 16, 18, 0.52);
    border: 1px solid rgba(255, 244, 221, 0.2);
    backdrop-filter: blur(5px);
  }

  .brand:hover,
  .brand:focus-visible {
    text-decoration: none;
    color: #ffffff;
    border-bottom-color: transparent;
  }

  .context-wrap {
    display: grid;
    justify-items: end;
  }

  .theme-controls {
    display: flex;
    flex-wrap: wrap;
    justify-content: end;
    gap: 0.45rem;
  }

  .theme-switcher {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: calc(var(--type-kicker-tracking) * 0.75);
    color: #f3e9d1;
    font-weight: 700;
    padding: 0.3rem 0.45rem;
    background: rgba(15, 16, 18, 0.52);
    border: 1px solid rgba(255, 244, 221, 0.2);
    backdrop-filter: blur(5px);
  }

  .theme-switcher span {
    white-space: nowrap;
  }

  .theme-switcher select {
    border: 1px solid rgba(255, 244, 221, 0.2);
    background: rgba(14, 16, 19, 0.8);
    color: #fff4dd;
    padding: 0.22rem 0.38rem;
    border-radius: 0;
    font-size: 0.62rem;
    letter-spacing: calc(var(--type-kicker-tracking) * 0.4);
    text-transform: uppercase;
    min-width: 138px;
  }

  .site-nav {
    margin-top: 0;
    position: relative;
    z-index: 3;
    border-top: 1px solid rgba(255, 244, 221, 0.15);
    border-bottom: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
    background: rgba(10, 11, 13, 0.28);
    backdrop-filter: blur(14px) saturate(1.08);
  }

  .site-nav ul {
    width: min(1160px, 95vw);
    margin: 0 auto;
    padding: 0;
    list-style: none;
    display: flex;
    align-items: center;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .site-nav ul::-webkit-scrollbar {
    display: none;
  }

  .site-nav li {
    border-right: 1px solid var(--border);
  }

  .site-nav li:first-child {
    border-left: 1px solid var(--border);
  }

  .site-nav a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.8rem 1rem;
    min-height: 46px;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #e8dcc0;
    white-space: nowrap;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .site-nav a:hover,
  .site-nav a:focus-visible {
    background: rgba(255, 255, 255, 0.12);
    color: #ffffff;
    text-decoration: none;
  }

  .site-nav a.active {
    background: var(--accent);
    color: var(--accent-contrast);
  }

  .mobile-nav {
    display: none;
  }

  .mobile-nav ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }

  .mobile-nav a {
    min-height: 52px;
    display: grid;
    place-items: center;
    padding: 0.65rem 0.35rem calc(0.65rem + env(safe-area-inset-bottom));
    border-top: 1px solid var(--border);
    border-right: 1px solid var(--border);
    background: var(--mobile-nav-bg);
    color: var(--ink-soft);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: center;
  }

  .mobile-nav li:last-child a {
    border-right: none;
  }

  .mobile-nav a.active {
    background: var(--accent);
    color: var(--accent-contrast);
  }

  @media (max-width: 900px) {
    .site-header {
      position: static;
      background: transparent;
      backdrop-filter: none;
      border-bottom: none;
    }

    .desktop-header-row {
      display: none;
    }

    .masthead {
      display: none;
    }

    .banner-shell {
      height: clamp(220px, 56vw, 320px);
    }

    .banner-image {
      object-fit: cover;
      object-position: center center;
    }

    .banner-image-fill {
      display: none;
    }

    .site-nav {
      display: none;
    }

    .mobile-nav {
      display: block;
      position: sticky;
      top: 0;
      z-index: 45;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
      box-shadow: 0 8px 24px rgba(9, 7, 6, 0.18);
      backdrop-filter: blur(14px) saturate(1.08);
    }
  }

  @media (max-width: 900px) {
    .theme-controls {
      display: none;
    }
  }

  @media (min-width: 901px) {
    .banner-shell {
      display: none;
    }
  }

  @media (max-width: 640px) {

    .brand {
      font-size: 0.9rem;
      padding: 0.28rem 0.4rem;
    }

    .eyebrow {
      margin-bottom: 0.18rem;
    }
  }
</style>
