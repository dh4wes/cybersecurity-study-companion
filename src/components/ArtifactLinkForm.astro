---
const { weekId } = Astro.props;
---

<section class="card" aria-label="Artifact link form">
  <h3>Artifact Link</h3>
  <p class="small">Add the URL to your published weekly output (optional).</p>
  <div class="form-row">
    <label for={`artifact-${weekId}`}>Artifact URL</label>
    <input id={`artifact-${weekId}`} data-week-id={weekId} class="js-artifact-url" type="url" placeholder="https://..." />
  </div>
  <div class="form-row inline">
    <button class="secondary js-save-artifact" data-week-id={weekId} type="button">Save artifact URL</button>
    <p class="small js-artifact-state" data-week-id={weekId} aria-live="polite"></p>
  </div>
</section>

<style>
  .inline {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  label {
    font-weight: 600;
    color: var(--ink);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
  }

  .js-artifact-state {
    margin: 0;
  }
</style>
