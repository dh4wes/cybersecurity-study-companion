---
const { entry } = Astro.props;
const tags = Array.isArray(entry.tags)
  ? entry.tags
  : String(entry.tags || '')
      .split(',')
      .map((tag) => tag.trim())
      .filter(Boolean);
---

<article class="card journal-card" data-tags={tags.join('|').toLowerCase()}>
  <header class="section-header">
    <div>
      <p class="kicker">{entry.date || 'Draft'}</p>
      <h3>{entry.sourceName || entry.title || 'Untitled entry'}</h3>
    </div>
    <span class="badge neutral">{entry.status || 'Draft'}</span>
  </header>

  {entry.summary ? <p><strong>What happened:</strong> {entry.summary}</p> : null}
  {entry.rootCause ? <p><strong>Root cause:</strong> {entry.rootCause}</p> : null}
  {entry.control ? <p><strong>Control change:</strong> {entry.control}</p> : null}

  <div class="meta">
    {tags.map((tag) => (
      <span class="badge accent">{tag}</span>
    ))}
  </div>

  {entry.sourceUrl ? (
    <p class="small">
      Source:{' '}
      <a href={entry.sourceUrl} target="_blank" rel="noreferrer">
        {entry.sourceUrl}
      </a>
    </p>
  ) : null}
</article>

<style>
  .journal-card {
    display: grid;
    gap: 0.2rem;
  }

  .journal-card[hidden] {
    display: none;
  }
</style>
