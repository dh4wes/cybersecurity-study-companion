---
const { entry } = Astro.props;
const examClass =
  String(entry.exam_relevance || '').toLowerCase() === 'high'
    ? 'accent'
    : String(entry.exam_relevance || '').toLowerCase() === 'medium'
      ? 'neutral'
      : 'warn';

const whatItIs = entry.what_it_is || entry.definition || '';
const howItFunctions = entry.how_it_functions || entry.why_it_matters || '';
const whereItFits = entry.where_it_fits || '';
---

<article class="glossary-card card">
  <div class="section-header">
    <div>
      <p class="kicker">{entry.category || 'General'}</p>
      <h4>{entry.term}</h4>
    </div>
    <span class={`badge ${examClass}`}>Exam: {entry.exam_relevance}</span>
  </div>

  <ul class="glossary-bullets">
    <li>{whatItIs}</li>
    <li>{howItFunctions}</li>
    <li>{whereItFits}</li>
  </ul>

  {entry.related_terms?.length ? (
    <p class="small">
      <strong>Related:</strong>{' '}
      {entry.related_terms.slice(0, 4).map((termId) => (
        <span class="badge neutral">{termId}</span>
      ))}
    </p>
  ) : null}
</article>

<style>
  .glossary-card {
    padding: 0.85rem;
  }

  h4 {
    margin: 0;
    font-size: 0.9rem;
  }

  .glossary-bullets {
    margin: 0.35rem 0 0.55rem;
    padding-left: 1rem;
  }

  .glossary-bullets li {
    margin-bottom: 0.38rem;
  }
</style>
