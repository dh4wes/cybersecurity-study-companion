---
const { entry } = Astro.props;
const bullets = Array.isArray(entry.bullets) ? entry.bullets.filter(Boolean).slice(0, 3) : [];
---

<article class="glossary-card card">
  <div class="section-header">
    <div>
      <p class="kicker">{entry.category || 'General'}</p>
      <h4>{entry.term}</h4>
    </div>
  </div>

  <ul class="glossary-bullets">
    {bullets.map((bullet) => <li>{bullet}</li>)}
  </ul>
</article>

<style>
  .glossary-card {
    padding: 0.85rem;
  }

  h4 {
    margin: 0;
    font-size: 0.9rem;
  }

  .glossary-bullets {
    margin: 0.35rem 0 0.55rem;
    padding-left: 1rem;
  }

  .glossary-bullets li {
    margin-bottom: 0.38rem;
  }
</style>
