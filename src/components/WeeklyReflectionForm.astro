---
const { weekId } = Astro.props;
---

<section class="card" aria-label="Weekly reflection">
  <h3>Weekly Reflection</h3>
  <p class="small">Capture what improved, what still needs work, and what to revisit.</p>
  <div class="form-row">
    <label for={`reflection-${weekId}`}>Reflection</label>
    <textarea id={`reflection-${weekId}`} data-week-id={weekId} class="js-week-reflection" placeholder="Write your reflection for this week..."></textarea>
  </div>
  <div class="form-row inline">
    <button class="secondary js-save-reflection" data-week-id={weekId} type="button">Save reflection</button>
    <p class="small js-reflection-state" data-week-id={weekId} aria-live="polite"></p>
  </div>
</section>

<style>
  .inline {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  label {
    font-weight: 600;
    color: var(--ink);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
  }

  .js-reflection-state {
    margin: 0;
  }
</style>
