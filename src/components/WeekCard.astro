---
import { withBase } from '../lib/site-data.js';

const { week, compact = false, showProgress = false } = Astro.props;
const daySessionTypes = [...new Set(week.days.map((day) => day.session_type))];
const dayLaptopValues = [...new Set(week.days.map((day) => day.laptop_needed))];
const dayTaskTags = [...new Set(week.days.flatMap((day) => day.taskTagList))];
const lockImage = withBase('/images/lock.jpg');
---

<article
  class="card week-card js-week-card"
  data-week-id={week.id}
  data-week={week.week}
  data-phase={week.phase}
  data-session-types={daySessionTypes.join('|')}
  data-laptop-needs={dayLaptopValues.join('|')}
  data-task-tags={dayTaskTags.join('|')}
>
  <div class="week-card-media" aria-hidden="true">
    <img class="week-card-lock-image" src={lockImage} alt="" loading="lazy" />
  </div>
  <div class="card-top">
    <p class="kicker">Week {String(week.week).padStart(2, '0')} • {week.phase}</p>
    {showProgress ? (
      <label class="week-toggle">
        <input class="js-week-complete-toggle" type="checkbox" data-week-id={week.id} />
        <span>Completed</span>
      </label>
    ) : null}
  </div>
  <h3>{week.weekly_focus}</h3>
  <p><strong>Deliverable:</strong> {week.deliverable}</p>
  <p><strong>Checkpoint:</strong> {week.checkpoint}</p>
  <p>
    <strong>Primary resource:</strong>{' '}
    {week.primary_url ? (
      <a href={week.primary_url} target="_blank" rel="noreferrer">{week.primary_resource}</a>
    ) : (
      week.primary_resource
    )}
  </p>

  {compact ? null : (
    <div class="meta">
      <span class="badge neutral">7 day plan</span>
      <span class="badge accent">{week.days.filter((day) => day.session_type === 'Study').length} study days</span>
      <span class="badge neutral">{week.days.filter((day) => day.session_type === 'Review').length} review day</span>
      <span class="badge neutral">{week.days.filter((day) => day.session_type === 'Rest').length} rest day</span>
    </div>
  )}

  {showProgress ? <p class="small js-week-progress" data-week-id={week.id}></p> : null}
  <p class="small week-lock-copy js-week-lock-copy" data-week-id={week.id} hidden>
    Complete the previous week to unlock this one.
  </p>

  <p class="cta-wrap">
    <a class="btn secondary js-week-open-link" href={week.href || week.slug}>Open week page</a>
  </p>
</article>

<style>
  .week-card {
    display: grid;
    gap: 0.3rem;
    transition: border-color 0.15s linear, background 0.15s linear, color 0.15s linear, opacity 0.15s linear;
  }

  .week-card-media {
    display: none;
    margin: -1rem -1rem 0.4rem;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    min-height: 148px;
    background:
      linear-gradient(180deg, rgba(22, 18, 15, 0.08), rgba(22, 18, 15, 0.34)),
      color-mix(in srgb, var(--surface-soft) 78%, rgba(244, 234, 212, 0.08));
  }

  .week-card-lock-image {
    display: block;
    width: 100%;
    height: 180px;
    object-fit: cover;
    filter: saturate(0.7) contrast(0.92) brightness(0.78);
  }

  .week-card:hover {
    background: linear-gradient(180deg, var(--surface-hover-start), var(--surface-hover-end));
    border-color: var(--accent);
  }

  .week-card.is-locked {
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface) 84%, rgba(244, 234, 212, 0.08)), color-mix(in srgb, var(--surface-soft) 88%, rgba(22, 18, 15, 0.12)));
    border-color: color-mix(in srgb, var(--border) 88%, rgba(244, 234, 212, 0.16));
  }

  .week-card.is-locked:hover {
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface) 84%, rgba(244, 234, 212, 0.08)), color-mix(in srgb, var(--surface-soft) 88%, rgba(22, 18, 15, 0.12)));
    border-color: color-mix(in srgb, var(--border) 88%, rgba(244, 234, 212, 0.16));
  }

  .week-card.is-locked .week-card-media {
    display: block;
  }

  .week-card.is-locked .week-toggle {
    opacity: 0.45;
    pointer-events: none;
  }

  .week-card.is-locked .week-lock-copy {
    display: block;
    color: color-mix(in srgb, var(--ink-soft) 88%, var(--c-white));
  }

  .week-card.is-locked .js-week-open-link {
    pointer-events: none;
    opacity: 0.55;
    border-color: color-mix(in srgb, var(--border) 82%, rgba(244, 234, 212, 0.18));
    color: var(--ink-soft);
  }

  .week-card.is-complete {
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface) 70%, #000 30%), color-mix(in srgb, var(--surface) 55%, #000 45%));
    border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
  }

  .week-card.is-complete:hover {
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface) 65%, #000 35%), color-mix(in srgb, var(--surface) 50%, #000 50%));
    border-color: color-mix(in srgb, var(--accent) 60%, var(--border));
  }

  .week-card.is-complete h3,
  .week-card.is-complete p,
  .week-card.is-complete strong,
  .week-card.is-complete a,
  .week-card.is-complete label,
  .week-card.is-complete span {
    color: color-mix(in srgb, var(--ink) 85%, white 15%);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: start;
  }

  .week-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-light);
    white-space: nowrap;
  }

  .week-toggle input {
    margin: 0;
  }

  .week-card h3 {
    font-size: 1.05rem;
  }

  .cta-wrap {
    margin-top: 0.35rem;
    padding-top: 0.55rem;
    border-top: 1px dashed var(--border);
  }

  .js-week-card[hidden] {
    display: none;
  }
</style>
