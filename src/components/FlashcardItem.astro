---
const { card, showWeekDay = false } = Astro.props;
const cardType = String(card.type || '').toLowerCase();
const typeClass = cardType === 'definition' ? 'neutral' : cardType === 'application' ? 'accent' : 'warn';
---

<article class="flashcard-item card">
  <div class="section-header">
    <p class="kicker">{card.id}</p>
    <div class="meta">
      <span class={`badge ${typeClass}`}>{card.type}</span>
      <span class="badge neutral">{card.difficulty}</span>
    </div>
  </div>
  <p><strong>Q:</strong> {card.front}</p>
  <details>
    <summary>Reveal answer</summary>
    <p><strong>A:</strong> {card.back}</p>
  </details>

  {showWeekDay ? (
    <p class="small">
      <strong>Weeks:</strong> {(card.week_refs || []).join(', ')}
    </p>
  ) : null}
</article>

<style>
  .flashcard-item {
    padding: 0.85rem;
  }

  details {
    margin-top: 0.35rem;
  }

  summary {
    cursor: pointer;
    font-weight: 700;
    color: var(--accent);
    font-size: 0.82rem;
  }

  summary + p {
    margin-top: 0.4rem;
  }
</style>
