---
import TaskBadges from './TaskBadges.astro';
import ResourceLinkList from './ResourceLinkList.astro';
import GlossaryTermCard from './GlossaryTermCard.astro';
import FlashcardItem from './FlashcardItem.astro';
import NotesCtaPanel from './NotesCtaPanel.astro';

const {
  day,
  weekId,
  weekNumber,
  weeklyDeliverable = '',
  showProgressControls = true,
  glossaryEntries = [],
  flashcardEntries = []
} = Astro.props;

const sessionClass = day.session_type === 'Review' ? 'accent' : day.session_type === 'Rest' ? 'neutral' : 'success';
const glossaryHeading = day.session_type === 'Review' ? 'Weekly Review Glossary' : "Today's New Glossary Terms";
const flashcardHeading = day.session_type === 'Review' ? 'Weekly Review Flashcards' : "Today's New Flashcards";
const todoItems = Array.isArray(day.todoList)
  ? day.todoList
  : Array.isArray(day.todo)
    ? day.todo
    : [String(day.todo || '')].filter(Boolean);
const sourceLinks = Array.isArray(day.sourceLinks) ? day.sourceLinks : [];
---

<details
  id={day.id}
  class="card day-card js-day-card"
  data-day-id={day.id}
  data-week-id={weekId}
  data-session-type={day.session_type}
>
  <summary class="day-card-summary">
    <div class="summary-copy">
      <p class="kicker">Day {String(day.day).padStart(2, '0')} • {day.label}</p>
      <h3>{day.session_type} Session</h3>
      <p class="summary-objective">{day.session_objective}</p>
    </div>
    <div class="summary-side">
      <div class="meta">
        <span class={`badge ${sessionClass}`}>{day.session_type}</span>
        <span class="badge neutral">{day.hours}h</span>
      </div>
      <div class="complete-mini" aria-hidden="true">
        <p class="complete-mini-label">session archived</p>
        <div class="ascii-wrap">
          <pre class="ascii-frame frame-a">[SYS] scan: [====     ]</pre>
          <pre class="ascii-frame frame-b">[SYS] scan: [=======  ]</pre>
          <pre class="ascii-frame frame-c">[SYS] scan: [=========]</pre>
        </div>
      </div>
    </div>
  </summary>

  <div class="day-card-body">
    <TaskBadges day={day} />

    <p><strong>Objective:</strong> {day.session_objective}</p>
    <p><strong>Suggested split:</strong> {day.suggested_split}</p>

    <div>
      <p><strong>Tasks:</strong></p>
      <ul>
        {todoItems.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>

    {day.taskTagList.length > 0 ? (
      <p>
        <strong>Task tags:</strong>{' '}
        {day.taskTagList.map((tag) => (
          <span class="badge neutral">{tag}</span>
        ))}
      </p>
    ) : null}

    <ResourceLinkList
      primaryResource={day.primary_resource}
      primaryUrl={day.primary_url}
      supportResource={day.support_resource}
      supportUrl={day.support_url}
      sourceLinks={sourceLinks}
    />

    <section class="section glossary-section">
      <div class="section-header">
        <h4>{glossaryHeading}</h4>
        <span class="badge neutral">{glossaryEntries.length}</span>
      </div>

      {glossaryEntries.length ? (
        <div class="grid glossary-grid">
          {glossaryEntries.map((entry) => (
            <GlossaryTermCard entry={entry} />
          ))}
        </div>
      ) : (
        <p class="small">No required new glossary terms for this session. Optional: light weekly review.</p>
      )}
    </section>

    <section class="section flashcard-section">
      <div class="section-header">
        <h4>{flashcardHeading}</h4>
        <div class="meta">
          <span class="badge neutral">{flashcardEntries.length}</span>
          {flashcardEntries.length ? (
            <button type="button" class="ghost export-day-btn js-export-day-anki" data-day-id={day.id}>
              {day.session_type === 'Review' ? "Export review deck" : "Export new cards"}
            </button>
          ) : null}
        </div>
      </div>

      {flashcardEntries.length ? (
        <div class="grid flashcard-grid">
          {flashcardEntries.map((card) => (
            <FlashcardItem card={card} />
          ))}
        </div>
      ) : (
        <p class="small">No required new flashcards for this session. Optional: revisit the review deck.</p>
      )}
    </section>

    <section class="card checkpoint-box">
      <p><strong>Checkpoint:</strong> {day.checkpoint || day.deliverable_or_checkpoint}</p>
      <p><strong>Weekly deliverable context:</strong> {weeklyDeliverable}</p>
      <p class="small"><strong>Journal prompt:</strong> {day.journal_prompt}</p>
    </section>

    <NotesCtaPanel
      week={weekNumber}
      day={day.day}
      tab="day"
      title="Capture Private Notes"
      body="Write your freeform day notes in the separate local notes tool."
    />

    {showProgressControls ? (
      <section class="progress-controls" aria-label={`Progress controls for ${day.id}`}>
        <div class="toggles">
          <label>
            <input class="js-complete-toggle" type="checkbox" />
            Complete
          </label>
          <button class="js-block-toggle ghost" type="button">Mark blocked</button>
        </div>
        <p class="small js-day-state" aria-live="polite"></p>
      </section>
    ) : null}
  </div>
</details>

<style>
  .day-card {
    padding: 1rem;
  }

  .day-card-summary {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.8rem;
    cursor: pointer;
    list-style: none;
  }

  .day-card-summary::-webkit-details-marker {
    display: none;
  }

  .day-card-summary::marker {
    content: '';
  }

  .summary-objective {
    margin-bottom: 0;
  }

  .summary-copy {
    min-width: 0;
  }

  .summary-side {
    display: grid;
    justify-items: end;
    gap: 0.45rem;
    flex-shrink: 0;
  }

  .complete-mini {
    display: none;
    min-width: 230px;
    padding: 0.45rem 0.65rem;
    border: 1px solid color-mix(in srgb, var(--success) 45%, var(--border));
    background: color-mix(in srgb, var(--success) 22%, var(--surface));
  }

  .complete-mini-label {
    margin: 0 0 0.25rem;
    color: var(--success);
    font-size: 0.58rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .ascii-wrap {
    position: relative;
    height: 1.1rem;
    min-width: 190px;
  }

  .ascii-frame {
    position: absolute;
    inset: 0;
    margin: 0;
    opacity: 0;
    color: var(--success);
    font-size: 0.66rem;
    line-height: 1.1;
    white-space: pre;
    animation: ascii-cycle 1.35s steps(1) infinite;
  }

  .frame-b {
    animation-delay: 0.45s;
  }

  .frame-c {
    animation-delay: 0.9s;
  }

  .day-card-body {
    margin-top: 0.8rem;
  }

  ul {
    margin-top: 0.2rem;
    margin-bottom: 0.6rem;
    padding-left: 1rem;
  }

  .glossary-grid,
  .flashcard-grid {
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .checkpoint-box {
    padding: 0.85rem;
  }

  .export-day-btn {
    font-size: 0.62rem;
    padding: 0.28rem 0.52rem;
    letter-spacing: 0.08em;
  }

  .progress-controls {
    margin-top: 0.8rem;
    border-top: 1px dashed var(--border);
    padding-top: 0.7rem;
  }

  .toggles {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
  }

  label {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--ink);
    font-weight: 500;
  }

  .js-day-card.is-complete {
    border-color: color-mix(in srgb, var(--success) 55%, var(--border));
    background: color-mix(in srgb, var(--success) 24%, var(--surface));
  }

  .js-day-card.is-condensed {
    padding: 0.7rem 0.9rem;
  }

  .js-day-card.is-condensed .complete-mini {
    display: block;
  }

  .js-day-card.is-condensed:not([open]) .summary-objective {
    display: none;
  }

  .js-day-card.is-condensed:not([open]) .day-card-body {
    display: none;
  }

  .js-day-card.is-condensed:not([open]) .day-card-summary {
    align-items: center;
  }

  .js-day-card.is-blocked {
    border-color: color-mix(in srgb, var(--danger) 55%, var(--border));
    background: color-mix(in srgb, var(--danger) 11%, var(--surface));
  }

  @media (max-width: 900px) {
    .day-card:not([open]) > .day-card-body {
      display: none;
    }

    .day-card-summary {
      min-height: 48px;
    }

    .day-card-summary::after {
      content: '+';
      color: var(--accent);
      font-size: 1rem;
      line-height: 1;
    }

    .day-card[open] .day-card-summary::after {
      content: '-';
    }

    .summary-side,
    .complete-mini {
      width: 100%;
    }

    .day-card-summary {
      flex-direction: column;
    }
  }

  @keyframes ascii-cycle {
    0%,
    33% {
      opacity: 1;
    }
    34%,
    100% {
      opacity: 0;
    }
  }
</style>
