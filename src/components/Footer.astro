---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="shell">
    <p>Cybersecurity Study Companion. Static portfolio + study dashboard.</p>
    <p class="small">Local-first v1 ({year})</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid #d3dce8;
    margin-top: 2.2rem;
    background: #f9fbfe;
  }

  .shell {
    width: min(1160px, 95vw);
    margin: 0 auto;
    padding: 1rem 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.6rem;
  }

  p {
    margin: 0;
    color: #3d536f;
    font-size: 0.86rem;
  }
</style>
