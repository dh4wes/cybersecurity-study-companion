---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="shell">
    <p>Cybersecurity Study Companion. Static portfolio + study dashboard.</p>
    <p class="small">Local-first v1 ({year})</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 2.2rem;
    background: var(--surface);
  }

  .shell {
    width: min(1160px, 95vw);
    margin: 0 auto;
    padding: 0.92rem 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.55rem;
  }

  p {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.68rem;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    font-weight: 600;
  }
</style>
