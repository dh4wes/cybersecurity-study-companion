---
const { day } = Astro.props;
const yesNo = (value) => {
  if (typeof value === 'boolean') return value;
  return String(value || '').toLowerCase() === 'yes';
};
const taskFlags = [
  { label: 'Video', value: yesNo(day.video) },
  { label: 'Reading', value: yesNo(day.reading) },
  { label: 'Hands-on', value: yesNo(day.hands_on) },
  { label: 'Writing / Portfolio', value: yesNo(day.writing_portfolio) }
];

const laptopRaw = String(day.laptop_needed || 'recommended').toLowerCase();
const laptopLabel =
  laptopRaw === 'required' ? 'Required' : laptopRaw === 'no' ? 'Not needed' : 'Recommended';
const laptopClass = laptopRaw === 'required' ? 'warn' : laptopRaw === 'no' ? 'neutral' : 'accent';
---

<div class="task-badges" aria-label="Task metadata badges">
  {taskFlags.map((item) => (
    <span class={`badge ${item.value ? 'accent' : 'neutral'}`}>
      {item.label}: {item.value ? 'Yes' : 'No'}
    </span>
  ))}
  <span class={`badge ${laptopClass}`}>Laptop: {laptopLabel}</span>
</div>

<style>
  .task-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.6rem;
  }
</style>
