---
import Layout from '../../layouts/Layout.astro';
import { canonicalData, workloadRows } from '../../lib/site-data.js';
import { withBase } from '../../lib/site-data.js';
---

<Layout title={`${canonicalData.site.title} | About`} description="About this cybersecurity journey" currentPath={Astro.url.pathname}>
  <section class="section">
    <article class="card about-banner-card">
      <img src={withBase('/images/site-banner.png')} alt="Cybersecurity study guide banner art" />
    </article>
  </section>

  <section class="two-col section">
    <article class="card">
      <h2>Why This Site Exists</h2>
      <p>
        The public site shows a structured learning system with weekly deliverables, checkpoints, and artifacts that
        can be reviewed quickly by a hiring manager or mentor.
      </p>
      <p>
        The curriculum stays public and portfolio-focused. Personal notes stay local and separate in the notes tool.
      </p>
    </article>

    <article class="card">
      <h2>What The Roadmap Covers</h2>
      <ul>
        <li>Foundations: hardware, operating systems, Linux, and support workflows</li>
        <li>Networking: protocols, subnetting, packet analysis, and troubleshooting</li>
        <li>Security operations: risk, controls, detection, response, and automation basics</li>
        <li>Governance and delivery: resilience, reporting, portfolio packaging, and communication</li>
      </ul>
      <p>The goal is practical analyst evidence across 32 weeks, not a checklist of finished courses.</p>
    </article>
  </section>

  <section class="section card">
    <h2>Workbook Workload Model (Enrichment)</h2>
    <p class="small">This table is pulled from the workbook workload model sheet for planning context.</p>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Phase</th>
            <th>Resource / Activity</th>
            <th>Planned Hours</th>
            <th>Source</th>
            <th>Notes</th>
          </tr>
        </thead>
        <tbody>
          {workloadRows.map((row) => (
            <tr>
              <td>{row.phase}</td>
              <td>{row.resource_activity}</td>
              <td>{row.planned_content_hours}</td>
              <td>
                {row.source_url ? (
                  <a href={row.source_url} target="_blank" rel="noreferrer">
                    Link
                  </a>
                ) : (
                  'n/a'
                )}
              </td>
              <td>{row.notes}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</Layout>

<style>
  .about-banner-card {
    padding: 0;
    overflow: hidden;
  }

  .about-banner-card img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 420px;
    object-fit: cover;
    object-position: center;
  }

  .table-wrap {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
  }

  th,
  td {
    text-align: left;
    border-bottom: 1px solid var(--border);
    padding: 0.55rem;
    vertical-align: top;
  }

  th {
    color: var(--ink);
    background: var(--card-surface-base);
  }

  @media (max-width: 900px) {
    .about-banner-card img {
      max-height: none;
    }
  }
</style>
