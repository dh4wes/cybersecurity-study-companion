---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import { canonicalData, workloadRows } from '../../lib/site-data.js';
---

<Layout title={`${canonicalData.site.title} | About`} description="About this cybersecurity journey" currentPath={Astro.url.pathname}>
  <PageHero
    kicker="About This Journey"
    title="Proof-of-Work Cybersecurity Portfolio"
    description="This site tracks a 32-week cybersecurity roadmap and publishes weekly outputs, reflections, and deliverables as proof of learning."
  />

  <section class="two-col section">
    <article class="card">
      <h2>Bio (Placeholder)</h2>
      <p>
        I am building from IT support fundamentals toward analyst-level cybersecurity work. This site documents
        weekly proof-of-work, not just course completion.
      </p>
      <p class="small">Update this section with your personal background, certifications, and preferred sector focus.</p>
    </article>

    <article class="card">
      <h2>Target Roles</h2>
      <ul>
        <li>SOC Analyst</li>
        <li>Security Analyst</li>
        <li>GRC / Risk Analyst</li>
      </ul>
    </article>
  </section>

  <section class="two-col section">
    <article class="card">
      <h2>Why This Site Exists</h2>
      <p>
        The roadmap is intentionally public-facing: each week has a deliverable, checkpoint, and artifact trail
        that an employer can inspect quickly.
      </p>
      <p>
        The main layer stays portfolio-quality and curriculum-centered, while private note-taking remains isolated
        in the local notes tool.
      </p>
    </article>

    <article class="card">
      <h2>What The Roadmap Covers</h2>
      <ul>
        <li>Foundation: hardware, OS, Linux, and core IT support concepts</li>
        <li>Networking: protocols, subnetting, packet analysis, and troubleshooting</li>
        <li>Security: risk, controls, incidents, automation basics, and manager-ready communication</li>
        <li>GRC / Application: governance, resilience, defensive workflows, and portfolio packaging</li>
      </ul>
      <p>The scope is designed to produce practical analyst evidence over 32 weeks, not passive content consumption.</p>
    </article>
  </section>

  <section class="section card">
    <h2>Workbook Workload Model (Enrichment)</h2>
    <p class="small">This table is pulled from the workbook workload model sheet for planning context.</p>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Phase</th>
            <th>Resource / Activity</th>
            <th>Planned Hours</th>
            <th>Source</th>
            <th>Notes</th>
          </tr>
        </thead>
        <tbody>
          {workloadRows.map((row) => (
            <tr>
              <td>{row.phase}</td>
              <td>{row.resource_activity}</td>
              <td>{row.planned_content_hours}</td>
              <td>
                {row.source_url ? (
                  <a href={row.source_url} target="_blank" rel="noreferrer">
                    Link
                  </a>
                ) : (
                  'n/a'
                )}
              </td>
              <td>{row.notes}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</Layout>

<style>
  .table-wrap {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
  }

  th,
  td {
    text-align: left;
    border-bottom: 1px solid var(--border);
    padding: 0.55rem;
    vertical-align: top;
  }

  th {
    color: var(--ink);
    background: var(--surface-soft);
  }
</style>
