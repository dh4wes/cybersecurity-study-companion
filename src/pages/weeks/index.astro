---
import Layout from '../../layouts/Layout.astro';
import FilterBar from '../../components/FilterBar.astro';
import WeekCard from '../../components/WeekCard.astro';
import PageHero from '../../components/PageHero.astro';
import {
  canonicalData,
  weeks,
  clientWeeksLite,
  uniquePhases,
  uniqueSessionTypes,
  uniqueLaptopNeeds,
  uniqueTaskTags
} from '../../lib/site-data.js';
---

<Layout title={`${canonicalData.site.title} | Weeks`} description="Week archive with filters" currentPath={Astro.url.pathname}>
  <PageHero
    kicker="Week Archive"
    title="All Week Pages"
    description="Filter by phase, week, session type, laptop needed, and task tags. Open each week for daily cards, reflections, artifacts, and local notes."
  />

  <FilterBar
    phases={uniquePhases}
    weeks={weeks}
    sessionTypes={uniqueSessionTypes}
    laptopNeeds={uniqueLaptopNeeds}
    taskTags={uniqueTaskTags}
  />

  <section class="section">
    <div class="grid week-grid">
      {weeks.map((week) => (
        <WeekCard week={week} showProgress={true} />
      ))}
    </div>
  </section>

  <script id="weeks-data-json" type="application/json" set:html={JSON.stringify({ weeks: clientWeeksLite })}></script>
  <script>
    import '../../scripts/weeks-page.js';
  </script>
</Layout>

<style>
  .week-grid {
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
  }
</style>
