---
import Layout from '../../layouts/Layout.astro';
import DayCard from '../../components/DayCard.astro';
import WeeklyReflectionForm from '../../components/WeeklyReflectionForm.astro';
import ArtifactLinkForm from '../../components/ArtifactLinkForm.astro';
import NotesCtaPanel from '../../components/NotesCtaPanel.astro';
import { canonicalData, weeks, glossaryById, flashcardById } from '../../lib/site-data.js';

export const getStaticPaths = () =>
  weeks.flatMap((week) => {
    const cleanSlug = week.slugPath.replace(/^weeks\//, '');
    const paths = [
      {
        params: { slug: cleanSlug },
        props: { week }
      }
    ];

    const legacySlug = week.legacySlugPath?.replace(/^weeks\//, '');
    if (legacySlug && legacySlug !== cleanSlug) {
      paths.push({
        params: { slug: legacySlug },
        props: { week }
      });
    }

    return paths;
  });

const { week } = Astro.props;
const weekId = week.id;
const previousWeek = weeks.find((entry) => entry.week === week.week - 1) || null;
const phaseOrder = [...new Set(weeks.map((entry) => entry.phase))];
const phaseNumber = Math.max(1, phaseOrder.indexOf(week.phase) + 1);

const weekFlashcards = [];
const seenWeekFlashcards = new Set();
week.days.forEach((day) => {
  day.flashcard_ids.forEach((cardId) => {
    if (seenWeekFlashcards.has(cardId)) return;
    const card = flashcardById.get(cardId);
    if (!card) return;
    seenWeekFlashcards.add(cardId);
    weekFlashcards.push(card);
  });
});

const dayFlashcards = week.days.map((day) => ({
  dayId: day.id,
  dayNumber: day.day,
  label: day.label,
  cards: day.flashcard_ids.map((cardId) => flashcardById.get(cardId)).filter(Boolean)
}));
---

<Layout
  title={`${canonicalData.site.title} | Week ${String(week.week).padStart(2, '0')}`}
  description={week.weekly_focus}
  currentPath={Astro.url.pathname}
>
  <section class="hero section">
    <p class="kicker">Week {String(week.week).padStart(2, '0')} • {week.phase}</p>
    <h1>{week.weekly_focus}</h1>
    <p><strong>Deliverable:</strong> {week.deliverable}</p>
    <p><strong>Checkpoint:</strong> {week.checkpoint}</p>
    <article class="card week-lock-banner js-week-lock-banner" hidden>
      <h2>This week is locked</h2>
      <p class="js-week-lock-message">Complete the previous week to unlock this content.</p>
    </article>
    <div class="inline export-wrap">
      <button type="button" class="secondary js-export-week-anki">
        Export this week&apos;s flashcards to Anki (.tsv)
      </button>
      <span class="small js-week-anki-export-state" aria-live="polite"></span>
    </div>
    <label class="week-complete">
      <input type="checkbox" class="js-week-complete" />
      Mark week complete
    </label>
    <p class="small js-week-complete-state" aria-live="polite"></p>
  </section>

  <section class="section js-lockable-week-section">
    <div class="section-header">
      <h2>Daily Plan</h2>
      <p class="small">
        7 day sections with tasks, resources, day-level glossary, day-level flashcards, checkpoint context, and
        progress controls.
      </p>
    </div>
    <div class="grid day-grid">
      {week.days.map((day) => (
        <DayCard
          day={day}
          weekId={weekId}
          weekNumber={week.week}
          weeklyDeliverable={week.deliverable}
          glossaryEntries={day.glossary_ids.map((id) => glossaryById.get(id)).filter(Boolean)}
          flashcardEntries={day.flashcard_ids.map((id) => flashcardById.get(id)).filter(Boolean)}
        />
      ))}
    </div>
  </section>

  <section class="section two-col js-lockable-week-section">
    <article class="card">
      <h2>Weekly Output / Portfolio</h2>
      <p><strong>What to publish:</strong> {week.page?.what_to_publish || week.deliverable}</p>
      <p><strong>Suggested evidence:</strong> {week.page?.evidence_assets || 'Capture screenshots, notes, and links tied to the weekly checkpoint.'}</p>
      <p><strong>Publish when:</strong> {week.page?.publish_when || 'By the end of the review day after your recap pass.'}</p>
      <p><strong>Portfolio angle:</strong> {week.page?.portfolio_angle || week.checkpoint}</p>
      <NotesCtaPanel
        week={week.week}
        tab="week"
        title="Write Reflection in Notes Tool"
        body="Keep freeform reflection and artifact planning in the separate local notes app."
      />
    </article>

    <div class="grid">
      <ArtifactLinkForm weekId={weekId} />
      <WeeklyReflectionForm weekId={weekId} />
    </div>
  </section>

  <script
    id="week-data-json"
    type="application/json"
    set:html={JSON.stringify({
      weekId,
      weekNumber: week.week,
      previousWeekId: previousWeek?.id || null,
      previousWeekNumber: previousWeek?.week || null,
      previousWeekHref: previousWeek?.href || null,
      previousWeekActionableDayIds: previousWeek
        ? previousWeek.days.filter((day) => day.session_type !== 'Rest').map((day) => day.id)
        : [],
      phaseNumber,
      weekFlashcards,
      dayFlashcards
    })}
  ></script>
  <script>
    import '../../scripts/week-page.js';
  </script>
</Layout>

<style>
  .day-grid {
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }

  .week-complete {
    margin-top: 0.6rem;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-weight: 600;
    color: var(--ink-light);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
  }

  .inline {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .export-wrap {
    margin-top: 0.5rem;
  }

  .week-lock-banner {
    display: grid;
    gap: 0.35rem;
    margin-top: 0.85rem;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface-soft) 74%, rgba(244, 234, 212, 0.14)), color-mix(in srgb, var(--surface) 86%, rgba(22, 18, 15, 0.12)));
    border-color: color-mix(in srgb, var(--border) 78%, rgba(244, 234, 212, 0.18));
  }
</style>
