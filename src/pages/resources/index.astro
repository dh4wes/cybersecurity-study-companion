---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import { canonicalData } from '../../lib/site-data.js';

const resources = canonicalData.resources;
const categories = [...new Set(resources.map((item) => item.category))];
---

<Layout title={`${canonicalData.site.title} | Resources`} description="Resource hub grouped by category" currentPath={Astro.url.pathname}>
  <PageHero
    kicker="Resource Hub"
    title="Resources"
    description="Curated references by category with use case, best weeks, URLs, and notes."
  />

  <section class="section resources-grid">
    {categories.map((category) => (
      <article class="card">
        <div class="section-header">
          <h2>{category}</h2>
          <span class="badge neutral">{resources.filter((item) => item.category === category).length} items</span>
        </div>
        <ul class="list-reset">
          {resources
            .filter((item) => item.category === category)
            .map((item) => (
              <li class="resource-row">
                <h3>{item.resource}</h3>
                <p><strong>Use case:</strong> {item.use_case}</p>
                <p><strong>Best weeks:</strong> {item.best_weeks}</p>
                <p>
                  <strong>URL:</strong>{' '}
                  <a href={item.url} target="_blank" rel="noreferrer">
                    {item.url}
                  </a>
                </p>
                <p class="small">{item.notes}</p>
              </li>
            ))}
        </ul>
      </article>
    ))}
  </section>
</Layout>

<style>
  .resources-grid {
    display: grid;
    gap: 1rem;
  }

  .resource-row {
    border-top: 1px dashed var(--border);
    padding-top: 0.7rem;
    margin-top: 0.7rem;
  }

  .resource-row:first-child {
    border-top: none;
    padding-top: 0;
    margin-top: 0;
  }

  .resource-row h3 {
    margin-bottom: 0.4rem;
    font-size: 1rem;
  }
</style>
