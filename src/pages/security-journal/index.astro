---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import NotesCtaPanel from '../../components/NotesCtaPanel.astro';
import { canonicalData, securityJournalPrompts } from '../../lib/site-data.js';
---

<Layout
  title={`${canonicalData.site.title} | Security Journal`}
  description="Prompt-driven security journal guidance"
  currentPath={Astro.url.pathname}
>
  <PageHero
    kicker="Security Journal"
    title="Prompt-Driven Journal"
    description="Use these prompts and templates to practice incident thinking and management-ready communication. Write freeform entries in the separate local notes tool."
  />

  <section class="two-col section">
    <article class="card">
      <h2>What This Journal Is For</h2>
      <ul>
        <li>Turn technical events into clear management summaries.</li>
        <li>Practice linking incidents to preventive controls.</li>
        <li>Capture evidence and follow-up actions as portfolio proof-of-work.</li>
      </ul>
      <p class="small">
        The public route stays prompt-driven. All freeform drafting and personal notes live in the isolated Notes Tool.
      </p>
      <NotesCtaPanel
        tab="journal"
        title="Write Journal Entry"
        body="Open the local notes tool and save your security journal entries privately in-browser."
      />
    </article>

    <article class="card">
      <h2>Entry Template</h2>
      <pre>
Source:
Technical Summary:
Management Summary:
Prevention Ideas:
Next Action:
Evidence Link:
      </pre>
      <p class="small">Keep entries concise, evidence-based, and actionable.</p>
    </article>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Weekly Prompt Archive</h2>
      <p class="small">{securityJournalPrompts.length} prompts</p>
    </div>

    <div class="grid prompt-grid">
      {securityJournalPrompts.map((prompt) => (
        <article class="card prompt-card">
          <p class="kicker">Week {String(prompt.week).padStart(2, '0')} • {prompt.phase}</p>
          <h3>{prompt.title}</h3>
          <p>{prompt.prompt}</p>
          <p class="small">
            <strong>Focus tags:</strong>{' '}
            {(prompt.tags || []).map((tag) => (
              <span class="badge neutral">{tag}</span>
            ))}
          </p>
        </article>
      ))}
    </div>
  </section>
</Layout>

<style>
  pre {
    padding: 0.8rem;
    border: 1px dashed var(--border);
    background: var(--card-surface-base);
    white-space: pre-wrap;
  }

  .prompt-grid {
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .prompt-card h3 {
    font-size: 0.96rem;
    margin-bottom: 0.45rem;
  }
</style>
