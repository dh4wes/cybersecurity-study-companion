---
import Layout from '../layouts/Layout.astro';
import ProgressSummary from '../components/ProgressSummary.astro';
import PageHero from '../components/PageHero.astro';
import {
  canonicalData,
  weeks,
  clientWeeksLite,
  withBase,
  totalStudyDays,
  totalReviewDays
} from '../lib/site-data.js';

const firstWeek = weeks[0];
---

<Layout title={`${canonicalData.site.title} | Home`} description={canonicalData.site.subtitle} currentPath={Astro.url.pathname}>
  <PageHero
    description="Static 32-week cybersecurity roadmap with day-level tasks, canonical glossary terms, flashcards, progress tracking, and a separate local notes tool."
  >
    <div class="meta">
      <span class="badge neutral">Current phase: <strong class="js-current-phase">{firstWeek.phase}</strong></span>
      <span class="badge neutral">Current week: <strong class="js-current-week">Week 01</strong></span>
    </div>
    <p class="small">
      Progress tracking is browser-based so the site can stay fully static.
    </p>
  </PageHero>

  <section class="section">
    <article class="card">
      <div class="section-header">
        <h2>Current Week Focus</h2>
        <a class="btn secondary js-current-week-link" href={firstWeek.href}>Open Week 01 page</a>
      </div>
      <p><strong>Focus:</strong> <span class="js-current-focus">{firstWeek.weekly_focus}</span></p>
      <p><strong>Deliverable:</strong> <span class="js-current-deliverable">{firstWeek.deliverable}</span></p>
      <p><strong>Checkpoint:</strong> <span class="js-current-checkpoint">{firstWeek.checkpoint}</span></p>
    </article>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Progress Snapshot</h2>
      <a href={withBase('/progress/')}>Open full dashboard</a>
    </div>
    <ProgressSummary totalStudyDays={totalStudyDays} totalReviewDays={totalReviewDays} totalWeeks={weeks.length} />
  </section>

  <script id="home-data-json" type="application/json" set:html={JSON.stringify({ weeks: clientWeeksLite })}></script>
  <script>
    import '../scripts/home-page.js';
  </script>
</Layout>
