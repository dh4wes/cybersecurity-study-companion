---
import Layout from '../layouts/Layout.astro';
import ProgressSummary from '../components/ProgressSummary.astro';
import PageHero from '../components/PageHero.astro';
import {
  canonicalData,
  weeks,
  clientWeeksLite,
  withBase,
  totalStudyDays,
  totalReviewDays
} from '../lib/site-data.js';

const firstWeek = weeks[0];
---

<Layout title={`${canonicalData.site.title} | Home`} description={canonicalData.site.subtitle} currentPath={Astro.url.pathname}>
  <PageHero
    description="Static 32-week cybersecurity study roadmap with day-level tasks, canonical glossary terms, flashcards, progress tracking, and a separate local notes tool."
  >
    <div class="meta">
      <span class="badge neutral">Current phase: <strong class="js-current-phase">{firstWeek.phase}</strong></span>
      <span class="badge neutral">Current week: <strong class="js-current-week">Week 01</strong></span>
    </div>
    <p class="small">
      Progress tracking is browser-based so the site can stay fully static.
    </p>
  </PageHero>

  <section class="section">
    <article class="card">
      <div class="section-header">
        <h2>Current Week Focus</h2>
        <a class="btn secondary js-current-week-link" href={firstWeek.href}>Open Week 01 page</a>
      </div>
      <p><strong>Focus:</strong> <span class="js-current-focus">{firstWeek.weekly_focus}</span></p>
      <p><strong>Deliverable:</strong> <span class="js-current-deliverable">{firstWeek.deliverable}</span></p>
      <p><strong>Checkpoint:</strong> <span class="js-current-checkpoint">{firstWeek.checkpoint}</span></p>
    </article>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Progress Snapshot</h2>
      <a href={withBase('/progress/')}>Open full dashboard</a>
    </div>
    <ProgressSummary totalStudyDays={totalStudyDays} totalReviewDays={totalReviewDays} totalWeeks={weeks.length} />
  </section>

  <script id="home-data-json" type="application/json" set:html={JSON.stringify({ weeks: clientWeeksLite })}></script>
  <script>
    import '../scripts/home-page.js';
  </script>
</Layout>

<style>
  .js-current-week-link {
    position: relative;
    isolation: isolate;
    color: color-mix(in srgb, var(--accent) 82%, var(--c-white));
    border-color: color-mix(in srgb, var(--accent) 82%, rgba(244, 234, 212, 0.34));
    box-shadow:
      0 0 0 1px rgba(var(--accent-rgb), 0.16),
      0 0 14px rgba(var(--accent-rgb), 0.22),
      0 0 28px rgba(var(--accent-rgb), 0.12);
    text-shadow: 0 0 8px rgba(var(--accent-rgb), 0.18);
    animation: current-week-glow 2.4s ease-in-out infinite;
  }

  .js-current-week-link:hover,
  .js-current-week-link:focus-visible {
    box-shadow:
      0 0 0 1px rgba(var(--accent-rgb), 0.22),
      0 0 18px rgba(var(--accent-rgb), 0.3),
      0 0 34px rgba(var(--accent-rgb), 0.18);
  }

  .js-current-week-link[aria-disabled='true'] {
    animation: none;
    box-shadow: none;
    text-shadow: none;
  }

  @keyframes current-week-glow {
    0%,
    100% {
      box-shadow:
        0 0 0 1px rgba(var(--accent-rgb), 0.14),
        0 0 12px rgba(var(--accent-rgb), 0.2),
        0 0 24px rgba(var(--accent-rgb), 0.1);
    }

    50% {
      box-shadow:
        0 0 0 1px rgba(var(--accent-rgb), 0.22),
        0 0 18px rgba(var(--accent-rgb), 0.3),
        0 0 36px rgba(var(--accent-rgb), 0.16);
    }
  }
</style>
