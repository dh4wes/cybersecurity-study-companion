---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import FlashcardItem from '../../components/FlashcardItem.astro';
import {
  canonicalData,
  weeks,
  flashcardEntries,
  flashcardPhaseOptions,
  flashcardWeekOptions,
  flashcardDayOptions,
  flashcardTypeOptions,
  flashcardDifficultyOptions
} from '../../lib/site-data.js';

const phaseLabel = (value) =>
  String(value || '')
    .split('-')
    .map((token) => token.charAt(0).toUpperCase() + token.slice(1))
    .join(' ');

const dayLabel = (dayId) => {
  const match = String(dayId || '').match(/week-(\d+)-day-(\d+)/);
  if (!match) return dayId;
  return `Week ${match[1]} Day ${match[2]}`;
};

const phaseOrder = [...new Set(weeks.map((week) => week.phase))];
const weekToPhaseNumber = Object.fromEntries(
  weeks.map((week) => [week.week, phaseOrder.indexOf(week.phase) + 1])
);
const phaseRefToNumber = Object.fromEntries(
  weeks
    .filter((week) => week.phase_ref)
    .map((week) => [week.phase_ref, phaseOrder.indexOf(week.phase) + 1])
);
---

<Layout
  title={`${canonicalData.site.title} | Flashcards`}
  description="Study flashcards with day/week filters"
  currentPath={Astro.url.pathname}
>
  <PageHero
    kicker="Canonical Flashcards"
    title="Flashcards"
    description="Precomputed flashcard deck mapped to week/day study sessions with filters for phase, type, and difficulty."
  />

  <section class="card section">
    <div class="section-header">
      <h2>Export to Anki</h2>
      <a href="./export/">How to import into Anki</a>
    </div>

    <div class="anki-export-grid">
      <label>
        Deck base name
        <input class="js-anki-deck-base" type="text" value="CyberStudy" />
      </label>

      <label>
        Deck granularity
        <select class="js-anki-granularity">
          <option value="week" selected>By week</option>
          <option value="phase">By phase</option>
          <option value="one">One deck</option>
        </select>
      </label>
    </div>

    <label class="inline-check">
      <input class="js-anki-include-day-tags" type="checkbox" checked />
      Include day tags
    </label>

    <div class="filter-actions">
      <button type="button" class="js-export-anki-all">Export all cards (.tsv)</button>
      <button type="button" class="secondary js-export-anki-visible">Export current view (.tsv)</button>
      <p class="small js-anki-export-state" aria-live="polite"></p>
    </div>
  </section>

  <section class="card section">
    <h2>Filter Deck</h2>
    <div class="filter-grid">
      <label>
        Search question or answer
        <input class="js-flashcards-search" type="text" placeholder="mfa, subnetting, incident response..." />
      </label>

      <label>
        Phase
        <select class="js-flashcards-phase">
          <option value="">All phases</option>
          {flashcardPhaseOptions.map((phase) => <option value={phase}>{phaseLabel(phase)}</option>)}
        </select>
      </label>

      <label>
        Week
        <select class="js-flashcards-week">
          <option value="">All weeks</option>
          {flashcardWeekOptions.map((week) => (
            <option value={String(week)}>Week {String(week).padStart(2, '0')}</option>
          ))}
        </select>
      </label>

      <label>
        Day
        <select class="js-flashcards-day">
          <option value="">All days</option>
          {flashcardDayOptions.map((dayId) => <option value={dayId}>{dayLabel(dayId)}</option>)}
        </select>
      </label>

      <label>
        Card type
        <select class="js-flashcards-type">
          <option value="">All types</option>
          {flashcardTypeOptions.map((cardType) => <option value={cardType}>{cardType}</option>)}
        </select>
      </label>

      <label>
        Difficulty
        <select class="js-flashcards-difficulty">
          <option value="">All levels</option>
          {flashcardDifficultyOptions.map((difficulty) => (
            <option value={difficulty}>{difficulty}</option>
          ))}
        </select>
      </label>
    </div>

    <div class="filter-actions">
      <button type="button" class="secondary js-flashcards-reset">Reset filters</button>
      <p class="small js-flashcards-filter-state" aria-live="polite"></p>
    </div>
  </section>

  <section class="section">
      <div class="grid flashcards-grid">
        {flashcardEntries.map((card) => (
          <div
            class="js-flashcard-item"
            data-card-id={card.id}
            data-front={card.front}
            data-back={card.back}
            data-phase-refs={(card.phase_refs || []).join('|')}
            data-week-refs={(card.week_refs || []).join('|')}
            data-day-refs={(card.day_refs || []).join('|')}
            data-card-type={card.type}
            data-difficulty={card.difficulty}
          >
            <FlashcardItem card={card} showWeekDay={true} />
          </div>
        ))}
      </div>
  </section>

  <script
    id="flashcards-data-json"
    type="application/json"
    set:html={JSON.stringify({ cards: flashcardEntries, weekToPhaseNumber, phaseRefToNumber })}
  ></script>
  <script>
    import '../../scripts/flashcards-page.js';
  </script>
</Layout>

<style>
  .filter-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 0.7rem;
  }

  .filter-actions {
    margin-top: 0.6rem;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex-wrap: wrap;
  }

  .flashcards-grid {
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .js-flashcard-item[hidden] {
    display: none;
  }

  .anki-export-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.7rem;
    margin-bottom: 0.6rem;
  }

  .inline-check {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    text-transform: none;
    letter-spacing: 0.03em;
    font-weight: 600;
    font-size: 0.8rem;
    margin-bottom: 0.25rem;
  }
</style>
