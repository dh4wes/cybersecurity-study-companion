---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import GlossaryTermCard from '../../components/GlossaryTermCard.astro';
import {
  canonicalData,
  glossaryEntries,
  glossaryPhaseOptions,
  glossaryWeekOptions,
  glossaryCategoryOptions,
  glossaryTagOptions,
  glossaryExamOptions
} from '../../lib/site-data.js';

const phaseLabel = (value) =>
  String(value || '')
    .split('-')
    .map((token) => token.charAt(0).toUpperCase() + token.slice(1))
    .join(' ');

const grouped = glossaryEntries.reduce((acc, entry) => {
  const category = entry.category || 'General Security Foundations';
  if (!acc.has(category)) {
    acc.set(category, []);
  }
  acc.get(category).push(entry);
  return acc;
}, new Map());

const glossaryGroups = [...grouped.entries()]
  .map(([category, entries]) => ({
    category,
    entries: entries.sort((a, b) => a.term.localeCompare(b.term))
  }))
  .sort((a, b) => a.category.localeCompare(b.category));
---

<Layout title={`${canonicalData.site.title} | Glossary`} description="Searchable cybersecurity glossary" currentPath={Astro.url.pathname}>
  <PageHero
    kicker="Canonical Glossary"
    title="Glossary"
    description="Glossary terms are organized by category and each item shows what it is, how it functions, and where it fits in the IT/security workflow."
  />

  <section class="card section">
    <h2>Filter Terms</h2>
    <div class="filter-grid">
      <label>
        Search term or definition
        <input class="js-glossary-search" type="text" placeholder="cpu, subnet, risk register..." />
      </label>

      <label>
        Category
        <select class="js-glossary-category-filter">
          <option value="">All categories</option>
          {glossaryCategoryOptions.map((category) => <option value={category}>{category}</option>)}
        </select>
      </label>

      <label>
        Phase
        <select class="js-glossary-phase">
          <option value="">All phases</option>
          {glossaryPhaseOptions.map((phase) => <option value={phase}>{phaseLabel(phase)}</option>)}
        </select>
      </label>

      <label>
        Week
        <select class="js-glossary-week">
          <option value="">All weeks</option>
          {glossaryWeekOptions.map((week) => (
            <option value={String(week)}>Week {String(week).padStart(2, '0')}</option>
          ))}
        </select>
      </label>

      <label>
        Tag
        <select class="js-glossary-tag">
          <option value="">All tags</option>
          {glossaryTagOptions.map((tag) => <option value={tag}>{tag}</option>)}
        </select>
      </label>

      <label>
        Exam relevance
        <select class="js-glossary-exam">
          <option value="">All levels</option>
          {glossaryExamOptions.map((level) => <option value={level}>{level}</option>)}
        </select>
      </label>
    </div>

    <div class="filter-actions">
      <button type="button" class="secondary js-glossary-reset">Reset filters</button>
      <p class="small js-glossary-filter-state" aria-live="polite"></p>
    </div>
  </section>

  {glossaryGroups.map((group) => (
    <section class="section js-glossary-category" data-category={group.category}>
      <div class="section-header">
        <h2>{group.category}</h2>
        <span class="badge neutral js-glossary-category-count">{group.entries.length}</span>
      </div>

      <div class="grid glossary-grid">
        {group.entries.map((entry) => (
          <div
            class="js-glossary-item"
            data-category={entry.category}
            data-term-text={entry.term}
            data-definition-text={entry.definition}
            data-phase-refs={(entry.phase_refs || []).join('|')}
            data-week-refs={(entry.week_refs || []).join('|')}
            data-tags={(entry.tags || []).join('|')}
            data-exam={entry.exam_relevance}
            data-search-text={[entry.term, entry.definition, entry.what_it_is, entry.how_it_functions, entry.where_it_fits].join(' ')}
          >
            <GlossaryTermCard entry={entry} />
          </div>
        ))}
      </div>
    </section>
  ))}

  <script>
    import '../../scripts/glossary-page.js';
  </script>
</Layout>

<style>
  .filter-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 0.7rem;
  }

  .filter-actions {
    margin-top: 0.6rem;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex-wrap: wrap;
  }

  .glossary-grid {
    grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
  }

  .js-glossary-item[hidden],
  .js-glossary-category[hidden] {
    display: none;
  }
</style>
