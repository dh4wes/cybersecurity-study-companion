---
import Layout from '../../layouts/Layout.astro';
import PhaseTimeline from '../../components/PhaseTimeline.astro';
import PageHero from '../../components/PageHero.astro';
import { canonicalData, groupedWeeksByPhase } from '../../lib/site-data.js';
---

<Layout title={`${canonicalData.site.title} | Roadmap`} description="32-week timeline grouped by phase" currentPath={Astro.url.pathname}>
  <PageHero
    kicker="32-Week Timeline"
    title="Roadmap"
    description="Full 32-week timeline grouped by phase. Each week card includes focus, deliverable, checkpoint, primary resource, and a link to the detailed week page."
  />

  <PhaseTimeline groupedWeeks={groupedWeeksByPhase} />
</Layout>
