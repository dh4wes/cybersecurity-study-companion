---
import Layout from '../../layouts/Layout.astro';
import PhaseTimeline from '../../components/PhaseTimeline.astro';
import PageHero from '../../components/PageHero.astro';
import { canonicalData, clientWeeksLite, groupedWeeksByPhase } from '../../lib/site-data.js';
---

<Layout title={`${canonicalData.site.title} | Roadmap`} description="29-week timeline grouped by phase" currentPath={Astro.url.pathname}>
  <PageHero
    kicker="32-Week Timeline"
    title="Roadmap"
    description="Full 29-week timeline grouped by phase. Each week card includes focus, deliverable, checkpoint, primary resource, progress, and a link to the detailed week page."
  />

  <PhaseTimeline groupedWeeks={groupedWeeksByPhase} />

  <script id="roadmap-data-json" type="application/json" set:html={JSON.stringify({ weeks: clientWeeksLite })}></script>
  <script>
    import '../../scripts/roadmap-page.js';
  </script>
</Layout>
