---
import '../styles/global.css';
import BootIntro from '../components/BootIntro.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { pwaInfo } from 'virtual:pwa-info';
import pwaRegisterScript from '../scripts/pwa-register.ts?url';
import storageMigrateScript from '../scripts/storage-migrate.js?url';

const {
  title = 'Cybersecurity Study Companion',
  description = '32-week cybersecurity roadmap portfolio and study companion',
  currentPath = '/'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
    <script is:inline>
      (() => {
        try {
          const colorKey = 'cyber-study-color-theme-v1';
          const colorAllowed = new Set([
            'default',
            'inked',
            'amethyst-mint-harmony',
            'woodland',
            'jade-pebble-morning',
            'cocoa-topaz-noonday',
            'sorbet',
            'pearl',
            'driftwood-pearl-morning',
            'graphite'
          ]);
          const colorValue = localStorage.getItem(colorKey);
          if (colorAllowed.has(colorValue) && colorValue !== 'default') {
            document.documentElement.dataset.colorTheme = colorValue;
          }
        } catch {
          // Ignore localStorage errors.
        }
      })();
    </script>
    <script type="module" src={storageMigrateScript}></script>
    <script type="module" src={pwaRegisterScript}></script>
  </head>
  <body>
    <BootIntro />
    <Navbar currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
