---
import '../styles/global.css';
import BootIntro from '../components/BootIntro.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { withBase } from '../lib/site-data.js';
import {
  COLOR_THEME_STORAGE_KEY,
  FONT_THEME_STORAGE_KEY,
  allowedColorThemes,
  allowedFontThemes
} from '../lib/theme-options.js';
import { pwaInfo } from 'virtual:pwa-info';
import pwaRegisterScript from '../scripts/pwa-register.ts?url';
import storageMigrateScript from '../scripts/storage-migrate.js?url';

const {
  title = 'Cybersecurity Study Companion',
  description = '29-week cybersecurity study roadmap portfolio and study companion',
  currentPath = '/'
} = Astro.props;
const fallbackSite = new URL('https://dh4wes.github.io');
const appIcon192 = new URL(withBase('/app-icon-192.png'), Astro.site ?? fallbackSite).toString();
const appIcon512 = new URL(withBase('/app-icon-512.png'), Astro.site ?? fallbackSite).toString();
const canonicalUrl = new URL(currentPath || '/', Astro.site ?? fallbackSite).toString();
---

<!doctype html>
<html lang="en" style={`--banner-theme-bg: url('${withBase('/images/banner-theme-bg.jpg')}');`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#070707" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={appIcon512} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={appIcon512} />
    <link rel="icon" href={appIcon192} />
    <link rel="apple-touch-icon" href={appIcon192} />
    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
    <script is:inline>
      (() => {
        try {
          const fontKey = {JSON.stringify(FONT_THEME_STORAGE_KEY)};
          const fontAllowed = new Set({JSON.stringify(allowedFontThemes)});
          const fontValue = localStorage.getItem(fontKey);
          if (fontAllowed.has(fontValue) && fontValue !== 'default') {
            document.documentElement.dataset.fontTheme = fontValue;
          }

          const colorKey = {JSON.stringify(COLOR_THEME_STORAGE_KEY)};
          const colorAllowed = new Set({JSON.stringify(allowedColorThemes)});
          const colorValue = localStorage.getItem(colorKey);
          if (colorAllowed.has(colorValue) && colorValue !== 'default') {
            document.documentElement.dataset.colorTheme = colorValue;
          }
        } catch {
          // Ignore localStorage errors.
        }
      })();
    </script>
    <script type="module" src={storageMigrateScript}></script>
    <script type="module" src={pwaRegisterScript}></script>
  </head>
  <body>
    <BootIntro />
    <Navbar currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
