---
import '../styles/global.css';
import BootIntro from '../components/BootIntro.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { pwaInfo } from 'virtual:pwa-info';
import pwaRegisterScript from '../scripts/pwa-register.ts?url';

const {
  title = 'Cybersecurity Study Companion',
  description = '32-week cybersecurity roadmap portfolio and study companion',
  currentPath = '/'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
    <script is:inline>
      (() => {
        const key = 'cyber-study-font-theme-v1';
        const allowed = new Set(['default', 'pinkend']);
        try {
          const value = localStorage.getItem(key);
          if (allowed.has(value) && value !== 'default') {
            document.documentElement.dataset.fontTheme = value;
          }
        } catch {
          // Ignore localStorage errors.
        }
      })();
    </script>
    <script type="module" src={pwaRegisterScript}></script>
  </head>
  <body>
    <BootIntro />
    <Navbar currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
